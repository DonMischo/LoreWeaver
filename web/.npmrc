# Packages like lucide-react, @dnd-kit, @tiptap v2, and several Radix UI
# components declare peerDependencies of react@^18 but work correctly with
# React 19. This flag restores npm v6 behaviour (install anyway, don't error)
# until upstream packages update their peer dep declarations.
legacy-peer-deps=true

# next@16.x bundles postcss@8.4.x internally (GHSA-qx2v-qp2m-jg93 — moderate
# severity: XSS in PostCSS CSS stringify). The upstream fix requires next@16.3.0
# which is not yet released. For this local-first Electron app the attack surface
# is zero (no untrusted external CSS is ever processed). Skip audit noise until
# next ships the patched postcss; re-enable by removing the two lines below.
audit=false
fund=false
